# Модельный сценарий: произвели бы Predicted → гипотетический остаток/недобор

test['Реальный_Выпуск']   = test['Выпуск'].round().astype(int)
test['Реальный_Остаток']  = test['Остаток'].clip(lower=0).round().astype(int)

