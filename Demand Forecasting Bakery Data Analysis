model.fit(X_train, y_train)
y_pred_base = np.maximum(model.predict(X_test), 0)

print(f"Базовый MAE (без буфера): {mean_absolute_error(y_test, y_pred_base):.4f} шт.")

# ─────────────────────────────────────────────
