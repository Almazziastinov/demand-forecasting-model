        print(f"Предобработка завершена. Размер данных: {aggregated_df.shape}")
        return aggregated_df

    except Exception as e:
        print(f"Произошла ошибка при обработке: {e}")
        import traceback
        traceback.print_exc()
        return pd.DataFrame()

