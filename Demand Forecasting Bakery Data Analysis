        neg_stock  = (df['Остаток'] < 0).sum()
        neg_produced = (df['Выпуск'] < 0).sum()
        df['Продано'] = df['Продано'].clip(lower=0)
        df['Остаток']  = df['Остаток'].clip(lower=0)
        df['Выпуск']   = df['Выпуск'].clip(lower=0)
