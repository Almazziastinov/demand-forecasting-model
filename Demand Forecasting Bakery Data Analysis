)
model_base.fit(X_train, y_train)
y_pred_base = np.maximum(model_base.predict(X_test), 0)

# 3. Финальная модель (лучшие параметры из Optuna)
BEST_PARAMS = {
    'n_estimators':      1480,
    'learning_rate':     0.00559902887165902,
