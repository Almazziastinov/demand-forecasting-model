import pandas as pd
import numpy as np
import io
import os

def preprocess_data(file_path='beigl_data.xlsx'):
    """
    Загружает данные, обрабатывает аномалии и создает признаки (лаги и скользящие средние).
    """
    try:
        # Проверка существования файла
        if not os.path.exists(file_path):
            print(f"Ошибка: Файл {file_path} не найден.")
            return pd.DataFrame()

        print(f"Загрузка данных из: {file_path}...")
        df = pd.read_excel(file_path)

        # 1. Обработка аномалий: замена отрицательных значений на 0
        df['Продано'] = df['Продано'].clip(lower=0)
        df['Остаток'] = df['Остаток'].clip(lower=0)
        df['Выпуск'] = df['Выпуск'].clip(lower=0)

        # 2. Временные признаки
        df['Дата'] = pd.to_datetime(df['Дата'])
        df['ДеньНедели'] = df['Дата'].dt.dayofweek
        df['День'] = df['Дата'].dt.day

        # 3. Агрегация до уровня Дата-Пекарня-Номенклатура
        # Группируем, чтобы убедиться, что у нас одна запись на ключ-день
        group_cols = ['Дата', 'Пекарня', 'Номенклатура', 'Категория', 'Город', 'ДеньНедели', 'День']
        aggregated_df = df.groupby(group_cols, as_index=False).agg({
            'Продано': 'sum',
            'Выпуск': 'sum',
            'Остаток': 'sum'
        })

        # 4. Feature Engineering: Создание лагов (Lags)
        # Сортировка важна для корректного сдвига (shift)
        aggregated_df = aggregated_df.sort_values(by=['Пекарня', 'Номенклатура', 'Дата'])

        # Группируем по паре Пекарня-Номенклатура для вычисления лагов
        grouped = aggregated_df.groupby(['Пекарня', 'Номенклатура'])

        # Лаги продаж за последние 3 дня
        for lag in [1, 2, 3]:
            aggregated_df[f'sales_lag_{lag}'] = grouped['Продано'].shift(lag)

        # Скользящее среднее продаж за последние 3 дня (не включая текущий день)
        aggregated_df['sales_roll_mean_3'] = grouped['Продано'].transform(
            lambda x: x.shift(1).rolling(window=3, min_periods=1).mean()
        )

        # 5. Очистка от пустых значений, возникших при создании лагов
        # Так как данных всего за март, лаги откусят первые несколько дней для каждой позиции
